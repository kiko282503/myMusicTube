{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build MusicTube Debug",
            "type": "shell",
            "command": ".\\gradlew.bat",
            "args": [
                "assembleDebug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": {
                "owner": "gradle",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "severity": 3,
                    "message": 4
                }
            }
        },
        {
            "label": "Install MusicTube Debug",
            "type": "shell",
            "command": ".\\gradlew.bat",
            "args": [
                "installDebug"
            ],
            "group": "build",
            "dependsOn": "Build MusicTube Debug"
        },
        {
            "label": "Clean Project",
            "type": "shell",
            "command": ".\\gradlew.bat",
            "args": [
                "clean"
            ],
            "group": "build"
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": ".\\gradlew.bat",
            "args": [
                "test"
            ],
            "group": "test"
        },
        {
            "label": "Start Android Emulator",
            "type": "shell",
            "command": "emulator",
            "args": [
                "-avd",
                "MusicTube_Test"
            ],
            "isBackground": true,
            "group": "build"
        },
        {
            "label": "Build and Install",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build MusicTube Debug",
                "Install MusicTube Debug"
            ]
        }
    ]
}