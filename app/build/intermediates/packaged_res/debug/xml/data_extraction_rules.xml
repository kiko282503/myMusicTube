<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive data from cloud backup -->
        <exclude domain="cache" />
        <exclude domain="no_backup" />
    </cloud-backup>
    
    <device-transfer>
        <!-- Include user data for device transfer -->
        <include domain="file" path="." />
        <exclude domain="cache" />
    </device-transfer>
</data-extraction-rules>